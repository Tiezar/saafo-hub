# Google OAuth - mesmo Client ID configurado no backend
VITE_GOOGLE_CLIENT_ID="seu_google_client_id_aqui"

# URL da API do backend
VITE_API_URL="http://localhost:3000"

# Admin — emails que verão o link "Admin" na sidebar (separados por vírgula)
# A segurança real está no backend (ADMIN_EMAILS). Isso é apenas UX.
VITE_ADMIN_EMAILS="seuemail@exemplo.com"
