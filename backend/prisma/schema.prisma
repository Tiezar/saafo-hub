datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

enum EventType {
  EXAM
  DEADLINE
  FIXED_BLOCK
  REMINDER
  STUDY_SESSION
}

enum ReminderMethod {
  WHATSAPP
  EMAIL
}

model User {
  id                  String          @id @default(uuid())
  email               String          @unique
  name                String
  nickname            String?
  googleId            String?         @unique
  passwordHash        String?
  emailVerified       Boolean         @default(false)
  phone               String?
  institutionId       String?
  institution         Institution?    @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  plan                String          @default("FREE_TRIAL")
  trialEndsAt         DateTime?
  asaasCustomerId     String?         @unique
  asaasSubscriptionId String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  subjects            Subject[]
  cards               Card[]
  studySessions       StudySession[]
  studySpaces         StudySpace[]
  calendarEvents      CalendarEvent[]
  insightCache        InsightCache?
  examRecords         ExamRecord[]

  @@map("users")
}

model InsightCache {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  data        Json
  generatedAt DateTime @default(now())

  @@map("insight_caches")
}

model StudySpace {
  id             String          @id @default(uuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  color          String?
  icon           String?
  subjects       Subject[]
  calendarEvents CalendarEvent[]
  createdAt      DateTime        @default(now())

  @@map("study_spaces")
}

model Institution {
  id        String   @id @default(uuid())
  name      String   @unique
  sigla     String?
  uf        String?
  domains   String[]
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("institutions")
}

model Subject {
  id             String          @id @default(uuid())
  name           String
  color          String?
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  spaceId        String?
  space          StudySpace?     @relation(fields: [spaceId], references: [id], onDelete: SetNull)
  topics         Topic[]
  calendarEvents CalendarEvent[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@map("subjects")
}

model CalendarEvent {
  id               String          @id @default(uuid())
  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  spaceId          String?
  space            StudySpace?     @relation(fields: [spaceId], references: [id], onDelete: SetNull)
  subjectId        String?
  subject          Subject?        @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  title            String
  type             EventType
  startAt          DateTime
  endAt            DateTime?
  allDay           Boolean         @default(false)
  notes            String?
  color            String?
  recurrenceDays   Int[]
  recurrenceEndsAt DateTime?
  reminders        EventReminder[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@map("calendar_events")
}

model EventReminder {
  id            String        @id @default(uuid())
  eventId       String
  event         CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  minutesBefore Int
  method        ReminderMethod
  scheduledAt   DateTime
  sent          Boolean       @default(false)
  sentAt        DateTime?
  createdAt     DateTime      @default(now())

  @@index([scheduledAt, sent])
  @@map("event_reminders")
}

model Topic {
  id        String   @id @default(uuid())
  name      String
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  cards     Card[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("topics")
}

model Card {
  id          String       @id @default(uuid())
  front       String
  back        String
  topicId     String
  topic       Topic        @relation(fields: [topicId], references: [id], onDelete: Cascade)
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // SM-2 Spaced Repetition Fields
  repetitions Int          @default(0)
  interval    Int          @default(0)
  easeFactor  Float        @default(2.5)
  nextReview  DateTime     @default(now())
  
  reviews     CardReview[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("cards")
}

model StudySession {
  id        String       @id @default(uuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt DateTime     @default(now())
  endedAt   DateTime?
  reviews   CardReview[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@map("study_sessions")
}

model CardReview {
  id         String       @id @default(uuid())
  cardId     String
  card       Card         @relation(fields: [cardId], references: [id], onDelete: Cascade)
  sessionId  String
  session    StudySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  rating     Int
  reviewedAt DateTime     @default(now())

  @@map("card_reviews")
}

model ExamRecord {
  id        String        @id @default(uuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  topicId   String?
  topicName String
  mode      String        // 'multiple' | 'essay'
  questions Json
  createdAt DateTime      @default(now())
  attempts  ExamAttempt[]

  @@map("exam_records")
}

model ExamAttempt {
  id           String     @id @default(uuid())
  examRecordId String
  examRecord   ExamRecord @relation(fields: [examRecordId], references: [id], onDelete: Cascade)
  score        Int
  completedAt  DateTime   @default(now())

  @@map("exam_attempts")
}
