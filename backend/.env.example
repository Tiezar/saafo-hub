# URL de conexão com o banco de dados PostgreSQL
DATABASE_URL="postgresql://usuario:senha@localhost:5432/saafo_db?schema=public"

# Chave secreta de criptografia para geração de tokens JWT
JWT_SECRET="sua_chave_secreta_jwt_minimo_32_caracteres"

# Google Gemini API Key - obter em: aistudio.google.com
GEMINI_API_KEY="sua_gemini_api_key_aqui"

# Google OAuth - obter em: console.cloud.google.com -> APIs & Services -> Credentials
# Criar credenciais de tipo "Web application"
# Authorized JavaScript origins: http://localhost:5173
GOOGLE_CLIENT_ID="seu_google_client_id_aqui"

# Resend (Envio de e-mails de validação de conta) - obter em: resend.com
RESEND_API_KEY="re_sua_api_key_aqui"
RESEND_FROM_EMAIL="onboarding@resend.dev"

# Configurações de URL e CORS
API_URL="http://localhost:3000"
FRONTEND_URL="http://localhost:5173,http://localhost:5174"

# Evolution API (WhatsApp) - obter dados em sua instância configurada
EVOLUTION_API_URL="https://sua-instancia.evolution-api.com"
EVOLUTION_API_KEY="sua_evolution_api_key_aqui"
EVOLUTION_API_INSTANCE="nome_da_instancia_aqui"

# Asaas (Integração de Pagamento BR) - sandbox.asaas.com ou asaas.com
ASAAS_API_KEY="sua_asaas_api_key_aqui"
ASAAS_WEBHOOK_TOKEN="token_do_webhook_configurado_no_painel_asaas"
ASAAS_ENV="sandbox"

# Admin — emails separados por vírgula que terão acesso a /admin/*
ADMIN_EMAILS="seuemail@exemplo.com"
